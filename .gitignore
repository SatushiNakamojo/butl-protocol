# ══════════════════════════════════════════════

# BUTL Protocol — .gitignore

# ══════════════════════════════════════════════

# ── Secrets (NEVER commit private keys) ──

*.key
*.pem
*.secret
*.enc
my_identity.json
identity.json
contacts.json
chain_state.json
seed_phrase.txt
*.seed

# ── BUTL local data ──

.butl/

# ── Python ──

**pycache**/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.whl
.venv/
venv/
env/
ENV/
.Python
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
*.cover
.mypy_cache/
.ruff_cache/

# ── Rust ──

target/
Cargo.lock
**/*.rs.bk

# ── Node / JavaScript (future implementations) ──

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.npm/

# ── OS generated ──

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── IDE and editors ──

.vscode/
.idea/
*.swp
*.swo
*.swn
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ── Logs ──

*.log
logs/

# ── Temporary files ──

*.tmp
*.temp
*.bak
*.orig
/tmp/

# ── Archives (don’t commit build artifacts) ──

*.zip
*.tar.gz
*.tar.bz2
*.7z
*.rar.DS_Store git add .gitignore
